{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "article"
        }
      ],
      "destination": "/api/share"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "view",
          "value": "world-cup"
        }
      ],
      "destination": "/api/share"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
